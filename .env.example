# BPS Enrollment Chatbot — example environment variables
# Copy to .env and set values as needed. Do not commit .env (see .gitignore).

# Eligibility API (BPS Discover Service)
# Default: http://api.mybps.org/BPSDiscoverService/Schools.svc
# ELIGIBILITY_API_BASE_URL=http://api.mybps.org/BPSDiscoverService/Schools.svc

# Use mock eligibility client (no real API calls). Set to true/1/yes for UI testing.
# USE_MOCK_ELIGIBILITY=false

# Optional: request timeout in seconds for eligibility API calls (default 15).
# ELIGIBILITY_REQUEST_TIMEOUT=15

# Optional: API key if the eligibility service later requires auth (currently BPS Discover uses none).
# ELIGIBILITY_API_KEY=

# Web server port (default 7860).
# PORT=7860

# LLM (HuggingFace Inference API) for conversational flow. Optional: without these, the app still works with fixed prompts.
# Get a token at https://huggingface.co/settings/tokens
# HF_TOKEN=your_huggingface_token
# Model for chat (default: HuggingFaceH4/zephyr-7b-beta). Use a model that supports chat completion on the free tier.
# HF_INFERENCE_MODEL=HuggingFaceH4/zephyr-7b-beta
